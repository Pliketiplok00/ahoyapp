{
  "expo": {
    "name": "AhoyCrew",
    "slug": "ahoyapp",
    "owner": "pliketiplok",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ahoyapp",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0895C3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahoyapp.app",
      "associatedDomains": [
        "applinks:ahoy.bdot.house"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0895C3"
      },
      "package": "com.ahoyapp.app",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ahoy.bdot.house",
              "pathPrefix": "/auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Ahoy to access your camera for capturing receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ahoy to access your photos for selecting receipts."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Ahoy to access your location for tagging expenses."
        }
      ],
      "expo-mail-composer",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ad6fda9-d0da-42bb-b07c-49804137ffb3"
      }
    }
  }
}
