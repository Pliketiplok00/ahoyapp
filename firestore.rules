rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isSeasonMember(seasonId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/seasons/$(seasonId)/users/$(request.auth.uid));
    }
    // NEW: Helper function for private user data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    // NEW: Helper function to check if user is captain for a season
    function isCaptain(seasonId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/seasons/$(seasonId)/users/$(request.auth.uid)).data.roles.hasAny(['captain']);
    }
    match /seasons/{seasonId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSeasonMember(seasonId);
      match /users/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isSeasonMember(seasonId);
      }
      match /invites/{inviteId} {
        allow read: if isAuthenticated();
        allow create: if isSeasonMember(seasonId);
        allow update, delete: if isSeasonMember(seasonId);
      }

      // Pantry items - crew inventory management
      match /pantry/{itemId} {
        allow read, create, update, delete: if isSeasonMember(seasonId);
      }

      // Pantry sales - immutable audit trail
      match /pantrySales/{saleId} {
        allow read, create: if isSeasonMember(seasonId);
        allow update, delete: if false;
      }

      // ============ LOGS FEATURE ============

      // Defect Log - captain only can write, all crew can read
      match /defectLog/{entryId} {
        allow read: if isSeasonMember(seasonId);
        allow create, update, delete: if isCaptain(seasonId);
      }

      // Wish List - all crew can create, creator or captain can update/delete
      match /wishList/{itemId} {
        allow read: if isSeasonMember(seasonId);
        allow create: if isSeasonMember(seasonId);
        allow update, delete: if isSeasonMember(seasonId) &&
          (resource.data.createdBy == request.auth.uid || isCaptain(seasonId));
      }

      // Storage Map - per-user with visibility
      // Read: own entries OR public entries by others
      // Write: own entries only
      match /storageMap/{entryId} {
        allow read: if isSeasonMember(seasonId) &&
          (resource.data.createdBy == request.auth.uid || resource.data.isPublic == true);
        allow create: if isSeasonMember(seasonId) &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if isSeasonMember(seasonId) &&
          resource.data.createdBy == request.auth.uid;
      }
    }
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
      match /shoppingItems/{itemId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated();
      }
    }
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    match /apaEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    match /scoreEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
    // NEW: Private user data (income tracking)
    match /users/{userId} {
      // Users can only access their own data
      allow read, write: if isOwner(userId);

      // Income settings per season
      match /incomeSettings/{seasonId} {
        allow read, write: if isOwner(userId);
      }

      // Work days log
      match /workDays/{workDayId} {
        allow read, write: if isOwner(userId);
      }
    }
    match /_test/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
